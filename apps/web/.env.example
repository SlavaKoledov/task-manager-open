# Optional web-only override.
# Copy this file to `.env.local` when you need the web app to use a specific API base URL.
#
# Default behavior without this file:
#   VITE_API_BASE_URL=/api
#
# Example direct-to-backend development URL:
#   VITE_API_BASE_URL=http://localhost:8000/api

VITE_API_BASE_URL=/api
