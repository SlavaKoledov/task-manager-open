# Local development only.
# Copy this file to `.env` in the repo root before running Docker Compose
# or starting the backend directly from the host.

POSTGRES_DB=task_manager
POSTGRES_USER=task_manager
POSTGRES_PASSWORD=local-dev-password

# Direct backend runs from the host use localhost.
# Docker Compose overrides DATABASE_HOST to `db` inside the API container.
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Optional: override the derived SQLAlchemy connection string for backend-only runs.
# DATABASE_URL=postgresql+psycopg://task_manager:local-dev-password@localhost:5432/task_manager

# Optional: extend backend CORS origins as a JSON array.
# CORS_ORIGINS=["http://localhost","http://127.0.0.1","http://localhost:5173","http://127.0.0.1:5173"]
